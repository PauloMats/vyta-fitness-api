generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TRAINER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum TrainerStudentStatus {
  PENDING
  ACTIVE
  BLOCKED
}

enum WorkoutPlanVisibility {
  PRIVATE
  TRAINER_ONLY
  PUBLIC
}

enum WorkoutSessionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum PostVisibility {
  PRIVATE
  FRIENDS
  PUBLIC
}

enum MediaKind {
  AVATAR
  EXERCISE_IMAGE
  EXERCISE_VIDEO
  POST_IMAGE
  POST_VIDEO
}

enum NotificationType {
  TRAINING_REMINDER
  TRAINER_MESSAGE
  POST_LIKE
  POST_COMMENT
  FRIEND_REQUEST
  SYSTEM
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum AssessmentStatus {
  DRAFT
  COMPLETED
  ARCHIVED
  CANCELED
}

enum AssessmentType {
  INITIAL
  REASSESSMENT
}

enum ScreeningClearance {
  CLEARED
  RESTRICTED
  REFERRED
}

enum MeasurementSide {
  NONE
  LEFT
  RIGHT
}

enum AssessmentCircumferenceKind {
  NECK
  SHOULDERS
  CHEST
  WAIST
  ABDOMEN
  HIP
  ARM
  FOREARM
  THIGH
  CALF
}

enum AssessmentSkinfoldKind {
  TRICEPS
  SUBSCAPULAR
  BICEPS
  AXILLARY_MID
  SUPRAILIAC
  SUPRASPINAL
  ABDOMINAL
  THIGH
  CALF
  PECTORAL
}

enum BodyCompositionMethod {
  BIA
  SKINFOLD_JP3
  SKINFOLD_JP7
  DEXA
  MANUAL
}

enum FitnessTestCategory {
  CARDIO
  STRENGTH
  MOBILITY
  BALANCE
  FLEXIBILITY
}

enum AssessmentPhotoPosition {
  FRONT
  SIDE
  BACK
}

model User {
  id                   String            @id @default(cuid())
  email                String            @db.Citext
  username             String?           @db.Citext
  passwordHash         String
  fullName             String
  phone                String?
  avatarUrl            String?
  bio                  String?
  role                 UserRole          @default(STUDENT)
  status               UserStatus        @default(ACTIVE)
  emailVerifiedAt      DateTime?         @db.Timestamptz(3)
  lastLoginAt          DateTime?         @db.Timestamptz(3)
  passwordChangedAt    DateTime?         @db.Timestamptz(3)
  deletedAt            DateTime?         @db.Timestamptz(3)
  version              Int               @default(1)
  createdAt            DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime          @updatedAt @db.Timestamptz(3)
  refreshTokens        RefreshToken[]
  trainerProfile       TrainerProfile?
  studentProfile       StudentProfile?
  trainerRelationships TrainerStudent[]  @relation("TrainerRelationships")
  studentRelationships TrainerStudent[]  @relation("StudentRelationships")
  trainerWorkoutPlans  WorkoutPlan[]     @relation("PlanTrainer")
  studentWorkoutPlans  WorkoutPlan[]     @relation("PlanStudent")
  workoutSessions      WorkoutSession[]
  posts                Post[]
  comments             Comment[]
  postLikes            PostLike[]
  requestedFriendships Friendship[]      @relation("FriendshipRequester")
  receivedFriendships  Friendship[]      @relation("FriendshipAddressee")
  notifications        Notification[]
  deviceTokens         DeviceToken[]
  mediaAssets          MediaAsset[]
  trainerAssessments   PhysicalAssessment[] @relation("TrainerAssessments")
  studentAssessments   PhysicalAssessment[] @relation("StudentAssessments")

  @@index([role, status, deletedAt])
}

model RefreshToken {
  id                String         @id @default(cuid())
  userId            String
  sessionId         String
  familyId          String?
  tokenHash         String         @unique
  expiresAt         DateTime       @db.Timestamptz(3)
  revokedAt         DateTime?      @db.Timestamptz(3)
  revokedReason     String?
  replacedByTokenId String?
  lastUsedAt        DateTime?      @db.Timestamptz(3)
  userAgent         String?
  ipAddress         String?
  deviceId          String?
  createdAt         DateTime       @default(now()) @db.Timestamptz(3)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedByToken   RefreshToken?  @relation("RefreshTokenReplacements", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replacedTokens    RefreshToken[] @relation("RefreshTokenReplacements")

  @@index([userId, sessionId, revokedAt])
  @@index([userId, familyId])
  @@index([expiresAt])
}

model TrainerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  specialties     String[]
  yearsExperience Int?
  cref            String?
  priceNote       String?
  createdAt       DateTime @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @db.Timestamptz(3)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudentProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  currentHeightCm Decimal? @db.Decimal(5, 2)
  currentWeightKg Decimal? @db.Decimal(6, 2)
  targetWeightKg  Decimal? @db.Decimal(6, 2)
  limitations     String?
  createdAt       DateTime @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @db.Timestamptz(3)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrainerStudent {
  id        String               @id @default(cuid())
  trainerId String
  studentId String
  status    TrainerStudentStatus @default(PENDING)
  startedAt DateTime?            @db.Timestamptz(3)
  createdAt DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt DateTime             @updatedAt @db.Timestamptz(3)
  trainer   User                 @relation("TrainerRelationships", fields: [trainerId], references: [id], onDelete: Cascade)
  student   User                 @relation("StudentRelationships", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([trainerId, studentId])
  @@index([trainerId, status])
  @@index([studentId, status])
}

model WorkoutPlan {
  id          String                @id @default(cuid())
  trainerId   String
  studentId   String?
  title       String
  description String?
  goal        String?
  visibility  WorkoutPlanVisibility @default(TRAINER_ONLY)
  isTemplate  Boolean               @default(false)
  version     Int                   @default(1)
  createdAt   DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime              @updatedAt @db.Timestamptz(3)
  trainer     User                  @relation("PlanTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  student     User?                 @relation("PlanStudent", fields: [studentId], references: [id], onDelete: SetNull)
  days        WorkoutDay[]
  sessions    WorkoutSession[]

  @@index([trainerId, visibility])
  @@index([studentId])
  @@index([isTemplate])
}

model WorkoutDay {
  id               String      @id @default(cuid())
  workoutPlanId    String
  weekDay          Int
  order            Int
  title            String
  focus            String
  notes            String?
  estimatedMinutes Int
  version          Int         @default(1)
  workoutPlan      WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercises        WorkoutExercise[]
  sessions         WorkoutSession[]

  @@unique([workoutPlanId, order])
  @@index([workoutPlanId, weekDay])
}

model ExerciseLibrary {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  muscleGroup     String
  equipment       String?
  instructions    String
  defaultMediaUrl String?
  defaultThumbUrl String?
  version         Int               @default(1)
  createdAt       DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime          @updatedAt @db.Timestamptz(3)
  workoutItems    WorkoutExercise[]

  @@index([muscleGroup])
  @@index([name])
}

model WorkoutExercise {
  id                  String           @id @default(cuid())
  workoutDayId        String
  exerciseLibraryId   String?
  order               Int
  nameSnapshot        String
  muscleGroupSnapshot String?
  sets                Int
  reps                String
  restSeconds         Int
  tempo               String?
  rir                 Int?
  notes               String?
  mediaUrl            String?
  thumbUrl            String?
  workoutDay          WorkoutDay       @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  exerciseLibrary     ExerciseLibrary? @relation(fields: [exerciseLibraryId], references: [id], onDelete: SetNull)
  workoutSets         WorkoutSet[]

  @@unique([workoutDayId, order])
  @@index([exerciseLibraryId])
}

model WorkoutSession {
  id              String               @id @default(cuid())
  userId          String
  workoutPlanId   String?
  workoutDayId    String?
  status          WorkoutSessionStatus @default(IN_PROGRESS)
  startedAt       DateTime             @db.Timestamptz(3)
  finishedAt      DateTime?            @db.Timestamptz(3)
  durationSeconds Int?
  feelingPre      Int?
  feelingPost     Int?
  notes           String?
  createdAt       DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime             @updatedAt @db.Timestamptz(3)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutPlan     WorkoutPlan?         @relation(fields: [workoutPlanId], references: [id], onDelete: SetNull)
  workoutDay      WorkoutDay?          @relation(fields: [workoutDayId], references: [id], onDelete: SetNull)
  sets            WorkoutSet[]
  posts           Post[]

  @@index([userId, status])
  @@index([workoutPlanId])
  @@index([workoutDayId])
}

model WorkoutSet {
  id                String          @id @default(cuid())
  workoutSessionId  String
  workoutExerciseId String
  order             Int
  targetReps        Int?
  actualReps        Int?
  targetLoadKg      Decimal?        @db.Decimal(6, 2)
  actualLoadKg      Decimal?        @db.Decimal(6, 2)
  restSeconds       Int?
  completedAt       DateTime?       @db.Timestamptz(3)
  isWarmup          Boolean         @default(false)
  workoutSession    WorkoutSession  @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@unique([workoutSessionId, workoutExerciseId, order])
  @@index([workoutExerciseId])
}

model Post {
  id               String          @id @default(cuid())
  userId           String
  workoutSessionId String?
  mediaUrl         String?
  thumbUrl         String?
  mediaKind        MediaKind?
  caption          String?
  visibility       PostVisibility  @default(FRIENDS)
  createdAt        DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime        @updatedAt @db.Timestamptz(3)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutSession   WorkoutSession? @relation(fields: [workoutSessionId], references: [id], onDelete: SetNull)
  comments         Comment[]
  likes            PostLike[]

  @@index([userId, visibility])
  @@index([workoutSessionId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  text      String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

model Friendship {
  id          String           @id @default(cuid())
  pairKey     String           @unique
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime         @updatedAt @db.Timestamptz(3)
  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  readAt    DateTime?        @db.Timestamptz(3)
  createdAt DateTime         @default(now()) @db.Timestamptz(3)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MediaAsset {
  id               String            @id @default(cuid())
  userId           String
  kind             MediaKind
  provider         String
  bucket           String
  objectKey        String
  url              String
  mimeType         String?
  sizeBytes        Int?
  createdAt        DateTime          @default(now()) @db.Timestamptz(3)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentPhotos AssessmentPhoto[]

  @@index([userId, kind])
  @@index([objectKey])
}

model PhysicalAssessment {
  id              String            @id @default(cuid())
  studentId       String
  trainerId       String
  status          AssessmentStatus  @default(DRAFT)
  assessmentDate  DateTime          @db.Timestamptz(3)
  assessmentType  AssessmentType    @default(REASSESSMENT)
  notes           String?
  completedAt     DateTime?         @db.Timestamptz(3)
  version         Int               @default(1)
  createdAt       DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime          @updatedAt @db.Timestamptz(3)
  student         User              @relation("StudentAssessments", fields: [studentId], references: [id], onDelete: Cascade)
  trainer         User              @relation("TrainerAssessments", fields: [trainerId], references: [id], onDelete: Cascade)
  screening       AssessmentScreening?
  anamnesis       AssessmentAnamnesis?
  vitals          AssessmentVitals?
  circumferences  AssessmentCircumference[]
  skinfolds       AssessmentSkinfold[]
  bodyComposition AssessmentBodyComposition?
  fitnessTests    AssessmentFitnessTest[]
  photos          AssessmentPhoto[]
  report          AssessmentReport?

  @@index([studentId, assessmentDate(sort: Desc)])
  @@index([trainerId, assessmentDate(sort: Desc)])
  @@index([status, assessmentDate(sort: Desc)])
}

model AssessmentScreening {
  id               String             @id @default(cuid())
  assessmentId     String             @unique
  symptoms         String?
  knownConditions  String?
  medications      String?
  clearance        ScreeningClearance @default(CLEARED)
  riskFlags        String[]
  restrictions     String?
  observations     String?
  createdAt        DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime           @updatedAt @db.Timestamptz(3)
  assessment       PhysicalAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentAnamnesis {
  id                 String             @id @default(cuid())
  assessmentId       String             @unique
  objectivePrimary   String?
  objectiveSecondary String?
  activityLevel      String?
  sleepQuality       String?
  stressLevel        Int?
  familyHistory      String?
  injuriesHistory    String?
  limitations        String?
  observations       String?
  createdAt          DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime           @updatedAt @db.Timestamptz(3)
  assessment         PhysicalAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentVitals {
  id               String             @id @default(cuid())
  assessmentId     String             @unique
  weightKg         Decimal?           @db.Decimal(6, 2)
  heightCm         Decimal?           @db.Decimal(5, 2)
  bmi              Decimal?           @db.Decimal(5, 2)
  restingHeartRate Int?
  systolicBp       Int?
  diastolicBp      Int?
  spo2             Int?
  glucose          Decimal?           @db.Decimal(5, 2)
  createdAt        DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime           @updatedAt @db.Timestamptz(3)
  assessment       PhysicalAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentCircumference {
  id            String                     @id @default(cuid())
  assessmentId  String
  kind          AssessmentCircumferenceKind
  valueCm       Decimal                    @db.Decimal(5, 2)
  side          MeasurementSide            @default(NONE)
  protocol      String?
  order         Int
  notes         String?
  createdAt     DateTime                   @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime                   @updatedAt @db.Timestamptz(3)
  assessment    PhysicalAssessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, order])
  @@index([assessmentId, kind, side])
}

model AssessmentSkinfold {
  id               String                @id @default(cuid())
  assessmentId     String
  kind             AssessmentSkinfoldKind
  valueMm          Decimal               @db.Decimal(5, 2)
  side             MeasurementSide       @default(NONE)
  measurementIndex Int                   @default(1)
  protocol         String?
  createdAt        DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime              @updatedAt @db.Timestamptz(3)
  assessment       PhysicalAssessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, kind, measurementIndex])
}

model AssessmentBodyComposition {
  id             String                @id @default(cuid())
  assessmentId   String                @unique
  method         BodyCompositionMethod
  protocol       String?
  equation       String?
  bodyFatPercent Decimal?              @db.Decimal(5, 2)
  fatMassKg      Decimal?              @db.Decimal(6, 2)
  leanMassKg     Decimal?              @db.Decimal(6, 2)
  muscleMassKg   Decimal?              @db.Decimal(6, 2)
  visceralFat    Decimal?              @db.Decimal(5, 2)
  sourceDevice   String?
  isComparable   Boolean               @default(true)
  createdAt      DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime              @updatedAt @db.Timestamptz(3)
  assessment     PhysicalAssessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentFitnessTest {
  id           String               @id @default(cuid())
  assessmentId String
  category     FitnessTestCategory
  testCode     String
  name         String
  rawValue     String?
  unit         String?
  score        String?
  notes        String?
  metadata     Json?
  createdAt    DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime             @updatedAt @db.Timestamptz(3)
  assessment   PhysicalAssessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, category])
}

model AssessmentPhoto {
  id                String                  @id @default(cuid())
  assessmentId      String
  mediaAssetId      String
  position          AssessmentPhotoPosition
  consentAcceptedAt DateTime                @db.Timestamptz(3)
  createdAt         DateTime                @default(now()) @db.Timestamptz(3)
  assessment        PhysicalAssessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  mediaAsset        MediaAsset              @relation(fields: [mediaAssetId], references: [id], onDelete: Restrict)

  @@index([assessmentId, position])
}

model AssessmentReport {
  id              String             @id @default(cuid())
  assessmentId    String             @unique
  summary         String?
  recommendations String?
  warnings        String?
  generatedAt     DateTime?          @db.Timestamptz(3)
  createdAt       DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime           @updatedAt @db.Timestamptz(3)
  assessment      PhysicalAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}
